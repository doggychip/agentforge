# Database — Zeabur Postgres add-on auto-injects this
DATABASE_URL=postgresql://user:password@host:5432/agentforge

# Port — Zeabur sets this automatically
PORT=5000

# Session secret — change in production!
SESSION_SECRET=change-me-in-production

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Hugging Face — optional, for HF Inference agents
# Get token from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...
